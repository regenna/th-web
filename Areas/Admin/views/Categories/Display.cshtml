@model buingocluan_buoi4.Models.Category

@{
    ViewData["Title"] = "Chi tiết danh mục";
}

<h2>@ViewData["Title"]</h2>

<div class="card">
    <div class="card-body">
        <h4 class="card-title">Thông tin danh mục</h4>
        <p><strong>ID:</strong> @Model.Id</p>
        <p><strong>Tên danh mục:</strong> @Model.Name</p>
    </div>
</div>

<div class="mt-4">
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
    <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-primary">Chỉnh sửa</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Xóa</a>
</div>
